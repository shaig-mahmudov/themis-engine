# Copy this file to .env before running docker compose.
POSTGRES_PASSWORD=replace-with-a-long-random-password
THEMIS_API_KEY=replace-with-a-long-random-api-key
THEMIS_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Enable only when requests arrive through a trusted reverse proxy.
THEMIS_TRUST_FORWARDED_HEADERS=false
